# ── Anthropic (required for AI Import / Pro feature) ──────────────────────────
# Get this from: https://console.anthropic.com/
# Add to Vercel dashboard: Settings → Environment Variables
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe Payment Links (add after creating your Stripe account) ─────────────
# 1. Go to https://dashboard.stripe.com/payment-links
# 2. Create a "Monthly" recurring product at $14/month
# 3. Create a "Yearly" recurring product at $99/year
# 4. Copy the Payment Link URLs here
VITE_STRIPE_MONTHLY_URL=https://buy.stripe.com/...
VITE_STRIPE_YEARLY_URL=https://buy.stripe.com/...
